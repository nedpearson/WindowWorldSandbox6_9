{
  "name": "@wwa/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev --name init",
    "seed": "tsx prisma/seed.ts",
    "seed:measurement-rules": "tsx src/seeds/measurementRules.seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "generate": "prisma generate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "migrate:pricing": "tsx scripts/migratePricing.ts"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google-cloud/vision": "^5.3.6",
    "@google/genai": "^2.3.0",
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/client": "^6.8.2",
    "@supabase/supabase-js": "^2.106.1",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^3.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "@types/web-push": "^3.6.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prisma": "^6.8.2",
    "puppeteer": "^25.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
