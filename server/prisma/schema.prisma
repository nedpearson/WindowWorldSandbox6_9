model FinalReviewItem {
  id               String    @id @default(cuid())
  companyId        String
  customerId       String?
  appointmentId    String?
  /// Links this finding to a specific Opening record
  openingId        String?
  /// Rep user who triggered the check (derived server-side, never client-trusted)
  userId           String?
  sourceType       String
  sourceId         String?
  issueType        String?
  field            String?
  severity         String
  category         String
  /// Short human-readable title for the finding card
  title            String?
  message          String
  /// Human-readable suggested action text (advisory only — never auto-applied)
  suggestedAction  String?
  /// If true, user must explicitly approve before the system takes any action
  requiresApproval Boolean   @default(true)
  /// 0.0–1.0 confidence score, null for deterministic findings
  confidence       Float?
  /// Where this finding came from
  source           String? // deterministic_rule | ai_assistant | sync_engine | photo_qa | pricing_qa
  status           String    @default("open") // open | applied | ignored | reviewed | manager_review
  resolvedAt       DateTime?
  resolvedBy       String?
  resolutionAction String?
  overrideReason   String?
  metadataJson     String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@index([appointmentId])
  @@index([openingId])
  @@index([userId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

