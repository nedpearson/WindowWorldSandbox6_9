  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([userId])
  @@index([resolved])
}

model RepPerformance {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  performanceScore       Float    @default(0)
  trainingScore          Float    @default(0)
  manualCompletionPct    Float    @default(0)
  scenariosPassed        Int      @default(0)
  scenariosFailed        Int      @default(0)
  measurementErrorRate   Float    @default(0)
  contractErrorRate      Float    @default(0)
  followUpComplianceRate Float    @default(0)
  quoteToCloseRate       Float    @default(0)
  avgTimeToResolveHours  Float    @default(0)
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// NEW DRAWING ENGINE
// ═══════════════════════════════════════════════════════════

model FormSketch {
  id                    String   @id @default(uuid())
  appointmentId         String
  companyId             String?
  name                  String?
  completenessScore     Float?
  installerClarityScore Float?
  sketchSourceMode           String  @default("blank_canvas")
  backgroundVisualId         String?
  mapOutlineEnabled          Boolean @default(false)
  manualDrawingEnabled       Boolean @default(true)
  streetViewReferenceEnabled Boolean @default(false)
  exportBackgroundEnabled    Boolean @default(false)
  canvasData                 Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  appointment        Appointment                   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  layers             SketchLayer[]
  markers            SketchMarker[]
  validations        SketchMeasurementValidation[]
  pricingValidations SketchPricingValidation[]
  aiInterpretations  SketchAiInterpretation[]
  warnings           SketchWarningFlag[]
  scores             SketchCompletenessScore[]
  clarityScores      InstallerClarityScore[]
  markerGroups       SketchMarkerGroup[]

  @@index([appointmentId])
  @@index([companyId])
}

model SketchLayer {
  id        String   @id @default(uuid())
  sketchId  String
  companyId String?
  name      String
  isVisible Boolean  @default(true)
  zIndex    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchMarker {
  id                   String  @id @default(uuid())
  sketchId             String
  companyId            String?
  markerType           String // window | door | note | dimension | warning
  markerNumber         Int? // auto-incremented per sketch (X #1, X #2...)
  markerSymbol         String? // window_x | front_door | patio_door | special_shape | oriel | note | arrow
  markerLabel          String? // display label e.g. "X #1", "Front Door"
  windowType           String? // double_hung | picture | slider | casement | awning | patio_door | bso | special_shape | oriel | other
  shapeType            String? // arch | eyebrow | circle_top | quarter_arch | half_round | extended_leg | custom | other
  x                    Float
  y                    Float
  width                Float?
  height               Float?
  unitedInches         Float?
  elevation            String?
  roomLocation         String?
  floorNumber          Int?    @default(1)
  productType          String?
  specialtyType        String?
  installComplexity    String?
  ladderReq            Boolean @default(false)
  removalType          String?
  installType          String?
  exteriorMaterial     String?
  notes                String?
  pricingStatus        String?
  linkedOrderRowNumber Int? // maps to order form row number
  validationStatus     String? // incomplete | measured | priced | complete
  groupId              String? // link to SketchMarkerGroup

  // Multi-point measurement fields (VisualMeasurementAssistant / sketchSync)
  widthTop     Float?
  widthMiddle  Float?
  widthBottom  Float?
  heightLeft   Float?
  heightCenter Float?
  heightRight  Float?

  // Grid fields
  gridPattern         String?
  gridProfile         String?
  gridVerticalCount   Int?
  gridHorizontalCount Int?
  gridPlacement       String?
  sdlSize             String?
  isSDL               Boolean @default(false)
  isGBG               Boolean @default(false)
  gridStyle           String?

  // Oriel fields
  orielType             String?
  orielUpperSashHeight  Float?
  orielMeasurementBasis String?
  orielConfirmed        Boolean @default(false)

  // Shape fields (extended)
  shapeOrientation String?
  shapeRise        Float?
  shapeDiameter    Float?
  shapeCustomNote  String?

  // Exterior / surface fields
  exteriorSurface String?
  exteriorColor   String?
  interiorColor   String?

  // Product options
  glassPackage  String?
  screenOption  String?
  foamEnhanced  Boolean?
  temperedGlass String?
  obscureGlass  String?
  nailFin       Boolean?

  // Confirmation / validation tracking
  measurementVerified Boolean @default(false)
  hasPhoto            Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sketch       FormSketch                @relation(fields: [sketchId], references: [id], onDelete: Cascade)
  links        SketchMarkerLink[]
  group        SketchMarkerGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupMembers SketchMarkerGroupMember[]

  @@unique([sketchId, elevation, markerType, markerNumber])
  @@index([sketchId])
  @@index([companyId])
  @@index([groupId])
}

model SketchMarkerGroup {
  id               String   @id @default(uuid())
  sketchId         String
  companyId        String?
  groupType        String   @default("mull_pair") // mull_pair | twin | triple | bay_bow | field_note | other
  groupNote        String?
  keepSeparateRows Boolean  @default(true)
  needsReview      Boolean  @default(true)
  pricingReviewed  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sketch  FormSketch                @relation(fields: [sketchId], references: [id], onDelete: Cascade)
  markers SketchMarker[]
  members SketchMarkerGroupMember[]

  @@index([sketchId])
  @@index([companyId])
}

model SketchMarkerGroupMember {
  id        String   @id @default(uuid())
  groupId   String
  markerId  String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  group  SketchMarkerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  marker SketchMarker      @relation(fields: [markerId], references: [id], onDelete: Cascade)

  @@unique([groupId, markerId])
  @@index([groupId])
  @@index([markerId])
}

model SketchMarkerLink {
  id        String   @id @default(uuid())
  markerId  String
  openingId String?
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marker  SketchMarker @relation(fields: [markerId], references: [id], onDelete: Cascade)
  opening Opening?     @relation(fields: [openingId], references: [id], onDelete: SetNull)

  @@unique([markerId])
  @@unique([openingId])
  @@index([companyId])
}

model SketchMeasurementValidation {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  openingId       String?
  markerId        String?
  status          String // pass | fail | warning
  mismatchDetails String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchPricingValidation {
  id          String   @id @default(uuid())
  sketchId    String
  companyId   String?
  openingId   String?
  issueType   String // missing_labor | missing_specialty | missing_patio
  description String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchAiInterpretation {
  id                 String   @id @default(uuid())
  sketchId           String
  companyId          String?
  interpretationType String // warning | suggestion | labor | pricing
  message            String
  confidence         Float    @default(0.0)
  applied            Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchWarningFlag {
  id          String   @id @default(uuid())
  sketchId    String
  companyId   String?
  warningType String // unlinked_marker | missing_dimensions | access_issue
  description String
  severity    String // low | medium | high | critical
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchCompletenessScore {
  id        String   @id @default(uuid())
  sketchId  String
  companyId String?
  score     Float
  factors   String? // JSON string
  createdAt DateTime @default(now())

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model InstallerClarityScore {
  id        String   @id @default(uuid())
  sketchId  String
  companyId String?
  score     Float
  feedback  String?
  createdAt DateTime @default(now())

  sketch FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

// ═══════════════════════════════════════════════════════════
// BUSINESS RULES ENGINE
// ═══════════════════════════════════════════════════════════

model BusinessRule {
  id                     String    @id @default(cuid())
  ruleKey                String    @unique
  name                   String
  description            String
  category               String    @default("window_defaults") // sketch_marker | window_defaults | exterior_install | pricing | measurement | oriel | specialty_shape | mull_joined | tempered_glass | final_export
  isActive               Boolean   @default(true)
  severity               String    @default("high") // blocker | high | medium | low | info
  triggerField           String?
  operator               String?   // equals | not_equals | greater_than | less_than | contains | is_empty | is_not_empty
  triggerValue           String?
  triggerConditionJson   Json? // complex trigger conditions
  actionType             String // set_field | warn | require_confirmation | add_price | add_note | expand_abbreviation
  actionField            String?
  actionValue            String?
  actionJson             Json? // complex actions array
  message                String
  autoApply              Boolean   @default(true)
  requiresConfirmation   Boolean   @default(false)
  requiresOverrideReason Boolean   @default(false)
  effectiveDate          DateTime?
  needsVerification      Boolean   @default(false)
  companyId              String?

  // Guideline Metadata and Lifecycle
  priority               Int       @default(0)
  sourceDocument         String?
  sourceSection          String?
  sourcePage             String?
  fieldRepGuidance       String?
  installerNoteTemplate  String?
  orderFormImpact        String?
  contractImpact         String?
  pricingImpact          String?
  workbookMappingKey     String?
  appliesToAllReps       Boolean   @default(true)
  region                 String?
  createdBy              String?
  updatedBy              String?
  lastTestedAt           DateTime?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([companyId])
}

// ═══════════════════════════════════════════════════════════
// APPOINTMENT TIMELINE
// ═══════════════════════════════════════════════════════════

model AppointmentTimelineEvent {
