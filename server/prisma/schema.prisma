// ═══════════════════════════════════════════════════════════
// SKETCH EXPORT — Supabase Storage references for sketch PNGs
// Each SketchExport represents one rendered sketch PNG stored
// in the 'sketch-exports' bucket, scoped by company + appointment.
// ═══════════════════════════════════════════════════════════

model SketchExport {
  id              String    @id @default(cuid())
  companyId       String
  appointmentId   String
  createdByUserId String
  storageBucket   String
  storagePath     String
  mimeType        String    @default("image/png")
  widthPx         Int?
  heightPx        Int?
  sourceHash      String? // hash of marker data — used to detect staleness
  version         Int       @default(1)
  sourceUpdatedAt DateTime?
  metadataJson    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appointment        Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  generatedDocuments GeneratedDocument[]

  @@index([companyId])
  @@index([appointmentId])
  @@index([createdByUserId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════
// GENERATED DOCUMENT — Supabase Storage references for XLSX/PDF
// Each GeneratedDocument represents one XLSX or PDF stored in
// the 'generated-documents' bucket, scoped by company + appointment.
// Links to a SketchExport so we can detect when sketch has changed.
// ═══════════════════════════════════════════════════════════

model GeneratedDocument {
  id                   String   @id @default(cuid())
  companyId            String
  appointmentId        String
  customerId           String?
  createdByUserId      String
  documentType         String // order_form | proposal | contract | warranty | maintenance_agreement | finance_options
  status               String   @default("generating") // generating | ready | failed | stale
  storageBucket        String
  storagePath          String? // primary storage path (PDF if both, else XLSX)
  xlsxStoragePath      String?
  pdfStoragePath       String?
  mimeType             String   @default("application/pdf")
  fileName             String
  version              Int      @default(1)
  sourceSketchExportId String?
  metadataJson         Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  appointment        Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sourceSketchExport SketchExport? @relation(fields: [sourceSketchExportId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([appointmentId])
  @@index([customerId])
  @@index([createdByUserId])
  @@index([documentType])
  @@index([status])
  @@index([createdAt])
  @@index([sourceSketchExportId])
}

// -------------------------------------------------------
// FIELD MANUAL + INTERACTIVE TRAINING � Models
// -------------------------------------------------------

model FieldManualCategory {
  id          String   @id @default(cuid())
  companyId   String?
  slug        String
  title       String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles FieldManualArticle[]

  @@unique([slug, companyId])
  @@index([companyId])
  @@index([active])
}

model FieldManualArticle {
  id                       String   @id @default(cuid())
  companyId                String?
  categoryId               String?
  slug                     String
  title                    String
  summary                  String?
  bodyMarkdown             String   @db.Text
  decisionGuideJson        Json?
  doChooseJson             Json?
  doNotChooseJson          Json?
  requiredPhotosJson       Json?
  requiredMeasurementsJson Json?
  chargeableOptionsJson    Json?
  managerReviewFlagsJson   Json?
  commonMistakesJson       Json?
  installerNotesJson       Json?
  contractNotesJson        Json?
  relatedWindowTypesJson   Json?
  relatedDoorTypesJson     Json?
  relatedSidingTypesJson   Json?
  tagsJson                 Json?
  videoAssetsJson          Json?
  status                   String   @default("published") // draft | published | archived
  version                  Int      @default(1)
  createdByUserId          String?
  approvedByUserId         String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  category FieldManualCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([slug, companyId])
  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([createdByUserId])
  @@index([approvedByUserId])
}

model TrainingAsset {
  id                  String   @id @default(cuid())
  companyId           String?
  title               String
  description         String?
  sourceType          String // image | video | youtube | link | pdf
  sourceUrl           String
  embedUrl            String?
  thumbnailUrl        String?
  attribution         String?
  copyrightNote       String?
  approvedForTraining Boolean  @default(false)
  category            String?
  tagsJson            Json?
  metadataJson        Json?
  createdByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@index([sourceType])
  @@index([approvedForTraining])
}

model TrainingPath {
  id               String   @id @default(cuid())
  companyId        String?
  slug             String
  title            String
  description      String?
  roleTarget       String   @default("sales_rep") // sales_rep | manager | auditor | installer | all
  required         Boolean  @default(false)
  sortOrder        Int      @default(0)
  active           Boolean  @default(true)
  iconEmoji        String?
  estimatedMinutes Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lessons  TrainingLesson[]
  progress TrainingProgress[]
  reviews  ManagerTrainingReview[]

  @@unique([slug, companyId])
  @@index([companyId])
  @@index([roleTarget])
}

model TrainingLesson {
  id              String   @id @default(cuid())
  companyId       String?
  trainingPathId  String
  title           String
  summary         String?
  lessonType      String // article | video | quiz | scenario | measurement_practice | chargeback_sim | contract_sim
  bodyMarkdown    String?  @db.Text
  assetIdsJson    Json?
  quizJson        Json?
  scenarioJson    Json?
  sortOrder       Int      @default(0)
  passingScore    Int      @default(70)
  durationMinutes Int      @default(5)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  path      TrainingPath           @relation(fields: [trainingPathId], references: [id], onDelete: Cascade)
  progress  TrainingProgress[]
  questions TrainingQuestionBank[]

  @@index([companyId])
  @@index([trainingPathId])
}

model TrainingProgress {
  id             String    @id @default(cuid())
  companyId      String?
  userId         String
  trainingPathId String
  lessonId       String?
  status         String    @default("not_started") // not_started | in_progress | passed | failed | completed
  score          Int?
  attempts       Int       @default(0)
  timeSpentSec   Int       @default(0)
  completedAt    DateTime?
  metadataJson   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  path   TrainingPath    @relation(fields: [trainingPathId], references: [id], onDelete: Cascade)
  lesson TrainingLesson? @relation(fields: [lessonId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([trainingPathId])
  @@index([lessonId])
  @@index([status])
}

model TrainingQuestionBank {
  id                  String   @id @default(cuid())
  companyId           String?
  lessonId            String?
  questionType        String // multiple_choice | photo_choice | measurement | scenario | true_false
  questionText        String
  imageAssetId        String?
  videoAssetId        String?
  optionsJson         Json
  correctAnswerJson   Json
  explanationMarkdown String?  @db.Text
  difficulty          String   @default("intermediate") // beginner | intermediate | advanced
  tagsJson            Json?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  lesson TrainingLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([lessonId])
  @@index([questionType])
}

model ManagerTrainingReview {
  id             String    @id @default(cuid())
  companyId      String?
  userId         String
  reviewerUserId String
  trainingPathId String
  status         String    @default("pending") // pending | approved | rejected | needs_work
  notes          String?
  score          Int?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  path TrainingPath @relation(fields: [trainingPathId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([reviewerUserId])
  @@index([trainingPathId])
}

model ContentSource {
  id         String   @id @default(cuid())
  companyId  String?
  sourceName String
  sourceUrl  String
  sourceType String // website | youtube | google | manual_upload
  approved   Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([sourceType])
  @@index([approved])
}

// Maps a UI feature to a manual article/lesson for contextual help.
model ManualFeatureLink {
  id               String   @id @default(cuid())
  companyId        String?
  featureKey       String
  routePattern     String?
  componentKey     String?
  articleSlug      String?
  lessonId         String?
  validationRuleId String?
  helpLabel        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([featureKey, companyId])
  @@index([companyId])
  @@index([featureKey])
}

// ═══════════════════════════════════════════════════════════
// OFFLINE SYNC
// ═══════════════════════════════════════════════════════════

// Dedicated idempotency key table for offline push sync.
// Replaces the previous fragile AuditLog text-search approach.
// Keys are scoped to companyId+deviceId and expire after 7 days.
model SyncIdempotencyKey {
  id             String   @id @default(cuid())
  companyId      String
  userId         String
  deviceId       String
  idempotencyKey String   @unique
  entityType     String
  operation      String
  entityLocalId  String?
  entityCloudId  String?
  responseJson   String? // cached response for replay
  createdAt      DateTime @default(now())
  expiresAt      DateTime // set to createdAt + 7 days; cleaned up by cron
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([companyId, userId])
  @@index([expiresAt])
  @@index([deviceId])
}

// ═══════════════════════════════════════════════════════════
// FIELD INTELLIGENCE
// ═══════════════════════════════════════════════════════════

model FieldIntelligenceFinding {
  id               String    @id @default(cuid())
  companyId        String?
  appointmentId    String
  openingId        String?
  userId           String?
  category         String
  severity         String
  title            String
  message          String
  suggestedAction  String?
  status           String    @default("open") // open, applied, ignored, reviewed, manager_review
  requiresApproval Boolean   @default(false)
  confidence       Float     @default(1.0)
  source           String    @default("smart_check")
  metadataJson     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resolvedAt       DateTime?
  resolvedBy       String?

  @@index([companyId])
  @@index([appointmentId])
  @@index([openingId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// -----------------------------------------------------------
// QUOTE GROUPS & COMBINED QUOTES
// -----------------------------------------------------------

model QuoteGroup {
  id            String    @id @default(cuid())
  localId       String?
  cloudId       String?
  appointmentId String
  customerId    String?
  name          String
  description   String?
  status        String    @default("draft") // draft | presented | accepted | declined | archived
  sortOrder     Int       @default(0)
  isWholeJob    Boolean   @default(false)
  subtotal      Float     @default(0)
  discount      Float     @default(0)
  tax           Float     @default(0)
  total         Float     @default(0)
  pricingStatus String    @default("current") // current | stale | needs_review
  syncStatus    String    @default("synced") // offline sync state
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment    Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  openings       QuoteGroupOpening[]
  combinedQuotes CombinedQuoteGroup[]

  @@index([appointmentId])
  @@index([localId])
}

model QuoteGroupOpening {
  id                    String   @id @default(cuid())
  quoteGroupId          String
  openingId             String
  markerId              String?
  openingNumberSnapshot Int?
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  quoteGroup QuoteGroup @relation(fields: [quoteGroupId], references: [id], onDelete: Cascade)
  opening    Opening    @relation(fields: [openingId], references: [id], onDelete: Cascade)

  @@index([quoteGroupId])
  @@index([openingId])
}

model CombinedQuote {
  id             String    @id @default(cuid())
  localId        String?
  cloudId        String?
  appointmentId  String
  customerId     String?
  name           String
  description    String?
  status         String    @default("draft") // draft | presented | accepted | declined | archived
  subtotal       Float     @default(0)
  discount       Float     @default(0)
  tax            Float     @default(0)
  total          Float     @default(0)
  pricingStatus  String    @default("current") // current | stale | needs_review
  useForContract Boolean   @default(false)
  syncStatus     String    @default("synced")
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  appointment Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  quoteGroups CombinedQuoteGroup[]

  @@index([appointmentId])
  @@index([localId])
}

model CombinedQuoteGroup {
  id              String   @id @default(cuid())
  combinedQuoteId String
  quoteGroupId    String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  combinedQuote CombinedQuote @relation(fields: [combinedQuoteId], references: [id], onDelete: Cascade)
  quoteGroup    QuoteGroup    @relation(fields: [quoteGroupId], references: [id], onDelete: Cascade)

  @@index([combinedQuoteId])
  @@index([quoteGroupId])
}

model JobSiteVisit {
  id         String   @id @default(cuid())
  userId     String
  companyId  String?
  customerId String?
  siteName   String?
  address    String?
  city       String?
  state      String?  @default("LA")
  zip        String?
  visitedAt  DateTime @default(now())
  learned    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([visitedAt])
}

// ═══════════════════════════════════════════════════════════
// EMAIL LOG
// ═══════════════════════════════════════════════════════════

model EmailLog {
  id            String   @id @default(cuid())
  customerId    String
  companyId     String?
  sentByUserId  String
  toEmail       String
  fromEmail     String
  subject       String
  bodyText      String?
  bodyHtml      String?
  attachments   Json?    // Array of { name: string, url: string, storagePath: string }
  status        String   @default("sent") // sent | failed
  errorMessage  String?
  createdAt     DateTime @default(now())

  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sentBy        User     @relation(fields: [sentByUserId], references: [id])
  
  @@index([customerId])
  @@index([companyId])
}

// ── Sketch Annotations (Quick Notes) ────────────────────────────────────
model SketchAnnotation {
  id             String   @id @default(cuid())
  appointmentId  String
  sketchId       String?
  markerId       String?
  openingId      String?
  type           String   @default("note")
  text           String   @default("")
  x              Float    @default(0)
  y              Float    @default(0)
  width          Float    @default(120)
  height         Float    @default(60)
  rotation       Float?   @default(0)
  color          String?  @default("#FFEB3B")
  syncStatus     String   @default("clean")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@index([sketchId])
}

model AddressVisuals {
  id                      String   @id @default(uuid())
  appointmentId           String   @unique
  customerId              String?
  address                 String?
  lat                     Float?
  lng                     Float?
  provider                String   @default("mapbox")
  mapSnapshotId           String?
  satelliteSnapshotId     String?
  streetViewSnapshotId    String?
  propertyOutlineId       String?
  selectedPrimaryView     String   @default("map")
  rotationDegrees         Float    @default(0)
  bearingDegrees          Float    @default(0)
  pitchDegrees            Float    @default(0)
  zoom                    Float    @default(18)
  confirmedFrontElevation Boolean  @default(false)
  frontElevationDirection String?
  offlineReady            Boolean  @default(false)
  syncStatus              String   @default("clean")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

