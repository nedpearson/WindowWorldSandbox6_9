// ═══════════════════════════════════════════════════════════
// WORKBOOK TEMPLATE ENGINE TABLES
// ═══════════════════════════════════════════════════════════

model WorkbookTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  fileName      String
  filePath      String
  storageBucket String?
  isActive      Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions WorkbookTemplateVersion[]
  exports  WorkbookExportJob[]
}

model WorkbookTemplateVersion {
  id            String   @id @default(cuid())
  templateId    String
  versionNumber Int
  fileName      String
  filePath      String
  sheetNames    String[] // Array of sheet names detected
  isActive      Boolean  @default(false)
  changeNotes   String?
  createdBy     String?
