model WorkbookFieldValue {
  id              String    @id @default(cuid())
  mappingId       String
  appointmentId   String
  value           String?
  normalizedValue String?
  sourceType      String? // typed, voice, ai, rule, formula, manual
  sourceText      String?
  confidence      Float?
  reviewStatus    String    @default("pending") // pending, approved, rejected
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mapping WorkbookFieldMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([mappingId])
}

model WorkbookExportJob {
  id             String    @id @default(cuid())
  appointmentId  String
  templateId     String
  versionId      String?
  exportFormat   String    @default("xlsx") // xlsx, pdf
