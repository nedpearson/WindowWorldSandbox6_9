// ═══════════════════════════════════════════════════════════
// MOBILE RECORDING SYSTEM
// Voice/audio recordings captured in the field, with transcripts
// and AI-extracted field values for opening measurements.
// ═══════════════════════════════════════════════════════════

model MobileRecording {
  id            String                           @id @default(cuid())
  userId        String
  appointmentId String?
  openingId     String?
  status        String                           @default("saved") // saved | processing | failed
  syncStatus    String                           @default("pending") // pending | synced | failed
  durationSecs  Float?
  fileUrl       String? // S3 or Supabase Storage URL (optional)
  transcripts   MobileRecordingTranscript[]
  extractions   MobileRecordingFieldExtraction[]
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt

  @@index([userId])
  @@index([appointmentId])
  @@index([openingId])
}

model MobileRecordingTranscript {
  id          String   @id @default(cuid())
  recordingId String
  text        String
  confidence  Float?
  startMs     Int?
  endMs       Int?
  speaker     String?
  createdAt   DateTime @default(now())

  recording MobileRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  updatedAt DateTime        @default(now()) @updatedAt

  @@index([recordingId])
}

model MobileRecordingFieldExtraction {
  id              String    @id @default(cuid())
  recordingId     String
  appointmentId   String?
  openingNumber   Int?
  targetTable     String // 'Opening' | 'Appointment'
  targetField     String
  rawValue        String?
  normalizedValue String?
  status          String    @default("pending") // pending | approved | rejected | applied
  appliedBy       String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recording MobileRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@index([appointmentId])
  @@index([status])
}

