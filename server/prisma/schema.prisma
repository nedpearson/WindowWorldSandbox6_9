model AppointmentQualityScore {
  id                         String   @id @default(cuid())
  appointmentId              String
  companyId                  String?
  // Core score (used by both AI scorer and mobile route)
  overallScore               Float?
  // Mobile quality-score route fields (POST /api/mobile/quality-score/:id)
