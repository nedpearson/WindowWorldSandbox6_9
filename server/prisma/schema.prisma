// ═══════════════════════════════════════════════════════════
// FINANCE MODULE — Financing options catalog + proposal selections
// ═══════════════════════════════════════════════════════════

/// Tracks a batch import of finance options from a spreadsheet.
model FinanceOptionImportBatch {
  id            String   @id @default(cuid())
  companyId     String? // null = global (super-admin seeded)
  uploadedById  String // userId who ran the import
  fileName      String
  originalPath  String?
  sheetNames    Json? // array of sheet names found
  rowCount      Int      @default(0)
  importedCount Int      @default(0)
  skippedCount  Int      @default(0)
  errorCount    Int      @default(0)
  status        String   @default("pending") // pending, completed, failed
  errorLog      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  options FinanceOption[]

  @@index([companyId])
  @@index([uploadedById])
  @@index([status])
}

/// A single finance option / payment plan (from spreadsheet or manually entered).
model FinanceOption {
  id            String  @id @default(cuid())
  companyId     String? // null = global; non-null = company-specific
  importBatchId String? // link to FinanceOptionImportBatch if imported

  // Identification (keeping planKey for backward compat)
  planKey     String  @unique // stable machine key, e.g. "zero-6mo"
  planCode    String? // lender plan code, e.g. "2317"
  lenderName  String? // lender/finance company name
  name        String // full program name, e.g. "6 months @ 0% interest"
  displayName String? // short customer-facing label

  // Terms
  termMonths             Int
  apr                    Float    @default(0) // annual rate, e.g. 6.99
  promoType              String // interest_free | fixed_rate | same_as_cash | cash_down | none
  promoAprPercent        Decimal? @db.Decimal(6, 4) // promo rate (often 0)
  deferredInterestMonths Int? // months of deferred interest
  sameAsCashMonths       Int? // same-as-cash period

  // Amount rules
  minimumAmount Decimal? @db.Decimal(12, 2)
  maximumAmount Decimal? @db.Decimal(12, 2)

  // Down payment
  downPaymentPercent Decimal? @db.Decimal(6, 4) // e.g. 0.50 for 50%
  downPaymentAmount  Decimal? @db.Decimal(12, 2) // fixed dollar amount

  // Monthly payment calculation
  monthlyPaymentFactor Decimal? @db.Decimal(12, 8) // e.g. 0.031249 for 36mo/6.99%
  paymentFormula       String? // kept for backward compat

  // Formula metadata
  formulaType String @default("zero_interest") // zero_interest | factor | amortized | half_down | custom
  formulaJson Json? // raw formula metadata from spreadsheet

  // Disclosure / legal
  disclosureText String?

  // Source tracking
  sourceSheet     String?
  sourceRowNumber Int?
  sourceHash      String? @unique // SHA-256 dedup key

  // Display
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  // Misc
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importBatch FinanceOptionImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  selections  AppointmentFinanceSelection[]

  @@index([companyId])
  @@index([importBatchId])
  @@index([planCode])
  @@index([termMonths])
  @@index([isActive])
  @@index([sourceHash])
}

/// Records which finance option a sales rep selected for an appointment/proposal.
model AppointmentFinanceSelection {
  id              String  @id @default(cuid())
  companyId       String? // company scoping
  appointmentId   String  @unique // one selection per appointment (or use non-unique if multi needed)
  financeOptionId String

  // Amounts at time of selection (snapshot — option may change later)
  jobAmount         Float? // = appt.totalAmount at time of selection
  downPaymentAmount Decimal? @db.Decimal(12, 2)
  amountFinanced    Float? // financedAmount
  monthlyPayment    Float? // estimatedMonthlyPayment

  // Term/rate overrides (captured at selection time)
  termMonths Int?
  aprPercent Decimal? @db.Decimal(6, 4)

  // Totals
  totalPayments Decimal? @db.Decimal(12, 2)
  totalInterest Decimal? @db.Decimal(12, 2)

  // Disclosure snapshot
  disclosureText String?

  // Workflow flags
  discussed Boolean @default(false) // discussed with customer
  inPacket  Boolean @default(false) // include in proposal packet

  selectedBy String? // userId
  selectedAt DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  financeOption FinanceOption @relation(fields: [financeOptionId], references: [id], onDelete: Cascade)

  @@index([financeOptionId])
  @@index([companyId])
  @@index([appointmentId])
}

model CustomerDocumentPacket {
  id            String    @id @default(cuid())
  appointmentId String
  customerId    String
  packetType    String    @default("standard") // standard, proposal, final
  status        String    @default("draft") // draft, assembled, exported
  exportFormat  String? // pdf, xlsx
  filePath      String?
  fileSize      Int?
  documents     Json? // Array of included document keys
  metadata      Json?
  createdBy     String?
  createdAt     DateTime  @default(now())
  exportedAt    DateTime?

  @@index([appointmentId])
  @@index([customerId])
}

model DocumentExportLog {
  id              String   @id @default(cuid())
  appointmentId   String
  documentKey     String
  documentVersion String?
  exportFormat    String?
  exportedBy      String?
  exportedAt      DateTime @default(now())
  metadata        Json?

  @@index([appointmentId])
  @@index([documentKey])
}

// ═══════════════════════════════════════════════════════════
// COMMISSION MODULE — Private sales rep commission tracking
// ═══════════════════════════════════════════════════════════

// ── Commission Catalog — reusable price/commission rate table ──
// Imported from the BTR Commission Sheet (CS-2400) and any future sheets.
// Each row is one line item with its price, commission type, and source info.
model CommissionCatalogItem {
  id        String  @id @default(cuid())
  companyId String? // null = global (super-admin seeded); non-null = company-specific

  // Classification
  category    String // Windows | Patio Doors | Options | Other Products | Additional Labor Charges | Value Plus / Energy Star Packs
  subcategory String? // Double Hung | Other Styles | Specialty Windows | etc.
  itemName    String // Human-readable label (e.g. "4000 DH Mech/Weld")
  sku         String? // e.g. "3001", "3001-FE"
  description String?

  // Price
  priceType    String   @default("fixed") // fixed | book | percent_off | job_amount | per_unit
  priceAmount  Decimal? @db.Decimal(12, 2) // e.g. 365.00 — null if BOOK/percent
  priceAmount2 Decimal? @db.Decimal(12, 2) // e.g. 135.00 for ranges like $115/$135
  pricePercent Decimal? @db.Decimal(6, 4) // e.g. -0.20 for "20% Off"

  // Commission
  commissionType    String   @default("fixed") // fixed | percent | none
  commissionAmount  Decimal? @db.Decimal(12, 2) // e.g. 20.00
  commissionPercent Decimal? @db.Decimal(6, 4) // e.g. 0.10 for 10%

  // Unit / per-unit context
  unit String? // foot | square_foot | pair | pane | unit | job — null = each

  // Source tracking
  sourceSheet     String? // sheet name in the workbook
  sourceRowNumber Int? // row number in the sheet (1-indexed)
  sourceHash      String? @unique // SHA-256 of key fields — prevents duplicate imports

  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([category])
  @@index([subcategory])
  @@index([isActive])
  @@index([sourceHash])
}

model CommissionImport {
  id              String    @id @default(cuid())
  userId          String
  sourceFileName  String
  sourceFilePath  String?
  sourceSheetName String?
  totalRows       Int       @default(0)
  importedRows    Int       @default(0)
  skippedRows     Int       @default(0)
  failedRows      Int       @default(0)
  status          String    @default("pending") // pending, mapping, importing, completed, failed
  mappingStatus   String    @default("needs_mapping") // needs_mapping, mapped, confirmed
  columnMapping   Json? // { sourceCol: appField } mapping
  metadata        Json? // workbook metadata, detected headers, etc.
  errorLog        Json?
  importedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows    CommissionImportRow[]
  records CommissionRecord[]

  @@index([userId])
  @@index([status])
}

model CommissionImportRow {
  id           String   @id @default(cuid())
  importId     String
  rowNumber    Int
  rawData      Json // Original cell values from the workbook
  mappedData   Json? // Mapped to app field names
  status       String   @default("pending") // pending, imported, skipped, failed, duplicate
  errorMessage String?
  recordId     String? // Link to created CommissionRecord
  createdAt    DateTime @default(now())

  import_   CommissionImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  updatedAt DateTime         @default(now()) @updatedAt

  @@unique([importId, rowNumber])
  @@index([importId])
  @@index([status])
}

model CommissionRecord {
  id              String  @id @default(cuid())
  userId          String
  importId        String?
  sourceFileName  String?
  sourceSheetName String?
  sourceRowNumber Int?

  // Customer / Job info
  customerName    String?
  customerId_     String? // WW customer ID from sheet
  customerAddress String?
  customerCity    String?
  customerState   String?
  customerZip     String?
  customerPhone   String?
  region          String?

  // Job details
  contractNumber String?
  orderNumber    String?
  soldDate       DateTime?
  installDate    DateTime?
  salesRepName   String?
  salesRepNumber String?
  result         String? // Sale result from sheet
  numWindows     Int?
  productTypes   Json? // Array of product types/counts

  // Financial
  jobAmount         Decimal? @db.Decimal(12, 2)
  totalSaleAmount   Decimal? @db.Decimal(12, 2)
  commissionableAmt Decimal? @db.Decimal(12, 2)
  commissionRate    Decimal? @db.Decimal(5, 4) // e.g. 0.08 for 8%
  commissionAmount  Decimal? @db.Decimal(12, 2)
  paidAmount        Decimal? @default(0) @db.Decimal(12, 2)
  unpaidAmount      Decimal? @db.Decimal(12, 2)
  adjustedAmount    Decimal? @db.Decimal(12, 2)
  adminFee          Decimal? @db.Decimal(12, 2)

  // Status tracking
  commissionStatus String    @default("imported") // imported, pending, expected, paid, partially_paid, disputed, adjusted, ignored
  paymentDate      DateTime?
  checkNumber      String?
  notes            String?
  comments         String?

  // Metadata
  metadata  Json?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  import_     CommissionImport?      @relation(fields: [importId], references: [id])
  links       CommissionRecordLink[]
  adjustments CommissionAdjustment[]
  payments    CommissionPayment[]

  @@index([userId])
  @@index([importId])
  @@index([commissionStatus])
  @@index([soldDate])
  @@index([customerName])
  @@index([isDeleted])
}

model CommissionRecordLink {
  id              String    @id @default(cuid())
  commissionId    String
  appointmentId   String?
  customerId      String?
  linkType        String    @default("manual") // manual, auto_suggested, confirmed
  matchConfidence Float? // 0-1 confidence score
  matchReason     String? // "address_match", "name_match", "date_match"
  confirmedAt     DateTime?
  confirmedBy     String?
  createdAt       DateTime  @default(now())

  commission CommissionRecord @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  updatedAt  DateTime         @default(now()) @updatedAt

  @@index([commissionId])
  @@index([appointmentId])
  @@index([customerId])
}

model CommissionAdjustment {
  id             String   @id @default(cuid())
  commissionId   String
  adjustmentType String // correction, bonus, deduction, chargeback
  amount         Decimal  @db.Decimal(12, 2)
  reason         String?
  notes          String?
  adjustedBy     String?
  adjustedAt     DateTime @default(now())

  commission CommissionRecord @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  updatedAt  DateTime         @default(now()) @updatedAt

  @@index([commissionId])
}

model CommissionPayment {
  id            String    @id @default(cuid())
  commissionId  String
  amount        Decimal   @db.Decimal(12, 2)
  paymentDate   DateTime?
  checkNumber   String?
  paymentMethod String? // check, direct_deposit, cash
  notes         String?
  recordedBy    String?
  createdAt     DateTime  @default(now())

  commission CommissionRecord @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  updatedAt  DateTime         @default(now()) @updatedAt

  @@index([commissionId])
  @@index([paymentDate])
}

