datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════════════════════════
// CORE TABLES
// ═══════════════════════════════════════════════════════════

model Company {
  jobSiteVisits JobSiteVisit[]
  id            String         @id @default(cuid())
  name          String
  tenantId      String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  users                      User[]
  customers                  Customer[]
  appointments               Appointment[]
  propertyImageCaches        PropertyImageCache[]
  propertyResearchProfiles   PropertyResearchProfile[]
  propertyResearchSources    PropertyResearchSource[]
  openingSuggestions         OpeningSuggestion[]
  quickQuoteResearchSessions QuickQuoteResearchSession[]
  propertyResearchImages     PropertyResearchImage[]
  openingEvidences           OpeningEvidence[]
  measurementRules           MeasurementRule[]
  followUps                  FollowUp[]
  pushSubscriptions          PushSubscription[]
  reviewActionLogs           ReviewActionLog[]
  appointmentPhotos          AppointmentPhoto[]
}

model User {
  jobSiteVisits JobSiteVisit[]
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  role          String         @default("sales_rep")
  password      String
  avatarUrl     String?
  measurementPreference String?      @default("outside_preferred")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyId     String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  appointments               Appointment[]
  auditLogs                  AuditLog[]
  voiceSessions              VoiceSession[]
  pricingVersions            PricingVersion[]
  timelineEvents             AppointmentTimelineEvent[]
  commissionImports          CommissionImport[]
  commissionRecords          CommissionRecord[]
  auditorIssues              AuditorIssue[]
  performance                RepPerformance?
  propertyImageCaches        PropertyImageCache[]
  propertyResearchProfiles   PropertyResearchProfile[]
  quickQuoteResearchSessions QuickQuoteResearchSession[]
  followUps                  FollowUp[]
  pushSubscriptions          PushSubscription[]
  reviewActionLogs           ReviewActionLog[]
  emailsSent                 EmailLog[]

  @@index([companyId])
}

model Customer {
  jobSiteVisits JobSiteVisit[]
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  phone2        String?
  address       String?
  city          String?
  state         String?        @default("LA")
  zip           String?
  notes         String?
  leadSource    String?
  preLead1978   Boolean        @default(false)
  customerId    String? // WW account/customer ID
  // ── Offline sync fields ──
  localId       String? // client-generated local ID for offline reconciliation
  version       Int            @default(1) // incremented on every server update for OCC
  deletedAt     DateTime? // soft delete for pull-sync tombstones
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyId     String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  appointments             Appointment[]
  propertyImageCaches      PropertyImageCache[]
  propertyResearchProfiles PropertyResearchProfile[]
  appointmentPhotos        AppointmentPhoto[]
  followUps                FollowUp[]
  emails                   EmailLog[]

  @@index([lastName, firstName])
  @@index([phone])
  @@index([updatedAt])
  @@index([companyId])
  @@index([localId])
  @@index([deletedAt])
}

model Appointment {
  id                     String    @id @default(cuid())
  customerId             String
  userId                 String
  status                 String    @default("draft")
  appointmentDate        DateTime?
  jobAddress             String?
  jobCity                String?
  jobState               String?   @default("LA")
  jobZip                 String?
  projectType            String?
  completeJob            Boolean   @default(true)
  poNumber               String?
  accountNumber          String?
  notes                  String?
  estimatorNotes         String?
  installerNotes         String?
  officeNotes            String?
  subtotal               Float     @default(0)
  taxRate                Float     @default(0.0945)
  taxAmount              Float     @default(0)
  adminFee               Float     @default(0)
  discount               Float     @default(0)
  totalAmount            Float     @default(0)
  depositAmount          Float     @default(0)
  balanceDue             Float     @default(0)
  financingAmount        Float     @default(0)
  jobLevelPriceConfirmed Boolean   @default(false) // set true when rep explicitly confirms job-level pricing
  pricingVersionId       String?
  completionPct          Float     @default(0)
  // ── QA / Manager Pricing Overrides ──
  qa2Price1              Float?
  qa2Price2              Float?
  qa2Price3              Float?
  qa2CommissionOverride  Float?
  qa2BonusAmount         Float?
  lockedAt               DateTime?
  lockedReason           String?
  followUpDate           DateTime? // next scheduled follow-up contact
  followUpOutcome        String? // last contact result: called | no_answer | left_message | meeting_set | sold | lost
  measurementPreference  String?   @default("outside_preferred") // outside_preferred | inside_preferred | auto_by_exterior
  pre1978Status          String    @default("unknown") // yes, no, unknown
  // ── Offline sync fields ──
  localId                String? // client-generated local ID for offline reconciliation
  version                Int       @default(1) // incremented on every server update for OCC
  deletedAt              DateTime? // soft delete so pull sync can return tombstones
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  companyId              String?

  // ── Synthetic AI Layer ──
  aiPredictedWindowCount Int?
  aiPredictedExterior    String?
  aiNeedsReview          Boolean @default(false)

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  customer                 Customer                      @relation(fields: [customerId], references: [id])
  user                     User                          @relation(fields: [userId], references: [id])
  pricingVersion           PricingVersion?               @relation(fields: [pricingVersionId], references: [id])
  openings                 Opening[]
  laserCaptures            LaserMeasurementCapture[]
  lineItems                QuoteLineItem[]
  contracts                Contract[]
  signatures               Signature[]
  payments                 Payment[]
  voiceSessions            VoiceSession[]
  formInstances            FormInstance[]
  formSketches             FormSketch[]
  timelineEvents           AppointmentTimelineEvent[]
  safetyReviews            OpeningSafetyGlazingReview[]
  temperedFlags            TemperedGlazingFlag[]
  aiWarnings               AiValidationWarning[]
  measurementAdj           MeasurementAdjustment[]
  measurePhotos            MeasurementCapturePhoto[]
  specialtySessions        SpecialtyMeasurementSession[]
  auditorIssues            AuditorIssue[]
  openingPhotos            OpeningPhoto[]
  appointmentPhotos        AppointmentPhoto[]
  propertyImageCaches      PropertyImageCache[]
  propertyResearchProfiles PropertyResearchProfile[]
  followUps                FollowUp[]
  reviewActionLogs         ReviewActionLog[]
  sketchExports            SketchExport[]
  sketchAnnotations        SketchAnnotation[]
  generatedDocuments       GeneratedDocument[]
  quoteGroups              QuoteGroup[]
  combinedQuotes           CombinedQuote[]
  syntheticInferences      SyntheticInference[]
  addressVisuals           AddressVisuals?

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([appointmentDate])
  @@index([followUpDate])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, appointmentDate])
  @@index([companyId, followUpDate])
  @@index([userId, status])
  @@index([userId, appointmentDate])
  @@index([localId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@index([companyId, updatedAt])
  @@index([userId, updatedAt])
}

// ═══════════════════════════════════════════════════════════
// OPENINGS
// ═══════════════════════════════════════════════════════════

model Opening {
  id              String  @id @default(cuid())
  appointmentId   String
  openingNumber   Int
  quantity        Int     @default(1)
  companyId       String?
  roomLocation    String?
  elevation       String?
  floorNumber     Int?    @default(1)
  width           Float?
  height          Float?
  unitedInches    Float?
  productType     String  @default("window") // window | patio_door | entry_door | siding | accessory | other
  productCategory String?
  productModel    String?
  seriesModel     String?

  // Door-specific fields
  doorType       String?
  doorPanelCount Int?
  doorSwing      String?
  doorHardware   String?

  // Siding-specific fields
  squareFootage      Float?
  stories            Int?
  sidingMaterial     String?
  headerFlashingFeet Float?
  jChannelFeet       Float?

  interiorColor               String?
  exteriorColor               String?
  gridStyle                   String?
  gridPattern                 String? // None | Colonial | Prairie | Diamond | Perimeter | Craftsman | Farmhouse | Custom | Other
  gridProfile                 String? // Flat | Contoured | SDL | GBG | Other
  gridVerticalCount           Int?      @default(0)
  gridHorizontalCount         Int?      @default(0)
  gridPlacement               String? // full | top_sash | bottom_sash | perimeter | custom
  gridNotes                   String?
  gridConfirmed               Boolean   @default(true)
  sdlSize                     String?
  isSDL                       Boolean   @default(false)
  isGBG                       Boolean   @default(false)
  gridRequiresAudit           Boolean   @default(false)
  glassPackage                String?
  temperedGlass               String? // none | full | half
  obscureGlass                String? // none | full | half
  argon                       Boolean   @default(false)
  foamEnhanced                Boolean   @default(false)
  rainObscure                 Boolean   @default(false)
  tapcon                      Boolean   @default(false)
  clearStory                  Boolean   @default(false)
  clearStoryIsFirst           Boolean   @default(false)
  stuccoRemoval               Boolean   @default(false)
  lowEPackage                 String?
  screenOption                String?
  nailFin                     Boolean   @default(false)
  oriel                       Boolean   @default(false)
  orielType                   String?
  orielUpperSashHeight        Float?
  orielMeasurementBasis       String?
  orielMeetingRailReference   String?
  orielConfirmed              Boolean   @default(false)
  orielNotes                  String?
  horizontalRR                Boolean   @default(false)
  hinge                       String?
  exteriorType                String?
  exteriorSurface             String? // vinyl_siding | wood_siding | stucco | brick | hardie | metal | existing_trim | mixed | unknown | other
  whatTouchesWindow           String? // Brick, Wood, Siding, Stucco, Trim, Other
  exteriorConditionNotes      String?
  requiresTrimHeader          Boolean   @default(false)
  requiresSpecialHandling     Boolean   @default(false)
  trimType                    String?
  trimNotes                   String?
  removalType                 String?
  installType                 String?
  sillRepair                  Boolean   @default(false)
  installNotes                String?
  customerNotes               String?
  installerNotes              String?
  copiedFromOpeningId         String?
  measurementConfirmed        Boolean   @default(true)
  safetyConfirmed             Boolean   @default(false)
  safetyGlazingStatus         String?
  safetyReviewStatus          String?
  safetyGlazingOverrideReason String?
  safetyGlazingReviewedAt     DateTime?
  basePrice                   Float     @default(0)
  optionsPrice                Float     @default(0)
  laborPrice                  Float     @default(0)
  totalPrice                  Float     @default(0)
  radius                      Float?
  customRadius                Float?
  legHeight                   Float?
  shapeType                   String?
  shapeOrientation            String?
  shapeSpringlineHeight       Float?
  shapeRise                   Float?
  shapeHighSide               Float?
  shapeLowSide                Float?
  shapeSlopeDirection         String?
  shapeAcrossFlats            Float?
  specialtyNotes              String?
  needsVerification           Boolean   @default(false)

  // -- Exterior Condition Rule Fields (added 2026-05-30) --
  specialShapeTrimRequired Boolean?
  specialShapeTrimSelected Boolean?
  specialShapeTrimPrice    Float?
  measurementMethod        String?
  outsideMeasureUsed       Boolean?
  cutbackLikely            Boolean?
  cutbackSelected          Boolean?
  cutbackReviewStatus      String?
  headerRequired           Boolean?
  headerSelected           Boolean?
  headerFlashingSelected   Boolean?
  trimRequiredReview       Boolean?
  trimDecision             String?
  trimDecisionReason       String?
  trimPhotoRequired        Boolean?
  trimSelected             Boolean?
  managerReviewRequired    Boolean?
  pricingStatus            String?  @default("pending")

  // ── Source of Truth Fields (added 2026-05-31) ──
  measurementBasis            String?  @default("outside") // outside | inside | both | needs_review
  measurementBasisDefaulted   Boolean? @default(true)
  measurementBasisOverridden  Boolean? @default(false)
  outsideMeasurementConfirmed Boolean? @default(false)
  insideMeasurementConfirmed  Boolean? @default(false)
  measurementBasisNotes       String?
  measurementNeedsReview      Boolean? @default(false)

  cutbackType            String?
  cutbackAmount          Float?
  cutbackIncludedInPrice Boolean?
  cutbackNotes           String?
  cutbackNeedsReview     Boolean?

  headerType            String?
  headerMaterial        String?
  headerColor           String?
  headerIncludedInPrice Boolean?
  headerNotes           String?
  headerNeedsReview     Boolean?

  trimIncludedInPrice Boolean?
  trimNeedsReview     Boolean?
  installMethod       String?

  // ── New measurement/cutback/guidance fields ──
  preferredMeasurementBasis         String?
  actualMeasurementBasis            String?
  cutbackRequired                   Boolean?
  removalDetail                     String?
  trimIncluded                      Boolean?
  headerFlashingIncluded            Boolean?
  measurementGuidanceAccepted       Boolean?
  measurementGuidanceOverrideReason String?
  outsidePhotoId                    String?
  measurementVisualAnnotationId     String?
  mullGroup                         String?
  installMullion                    Boolean? @default(false)
  structuralMullion                 Boolean? @default(false)


  // ── Laser Measurement Audit Fields (added 2026-05-31) ──
  // Preserve the raw field measurement separately from the ordered (deducted) size.
  // Allows audit trail of what was physically measured vs what was ordered.
  rawWidth              Float? // measured opening width (before deduction)
  rawHeight             Float? // measured opening height (before deduction)
  widthSource           String? // 'manual' | 'bluetooth_ble' | 'measureon_import' | 'typed'
  heightSource          String? // same
  widthRuleApplied      String? // rule name/id used (e.g. 'replacement_window_standard_deduction')
  heightRuleApplied     String? // rule name/id used
  widthDeductionInches  Float? // deduction applied to width (e.g. 0.375)
  heightDeductionInches Float? // deduction applied to height
  // ── Offline sync fields ──
  localId               String? // client-generated local ID for offline reconciliation
  version               Int       @default(1) // incremented on every server update for OCC
  deletedAt             DateTime? // soft delete for pull-sync tombstones
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  appointment        Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  photos             OpeningPhoto[]
  sketchLinks        SketchMarkerLink[]
  quoteGroupOpenings QuoteGroupOpening[]

  @@unique([appointmentId, openingNumber])
  @@index([appointmentId])
  @@index([companyId])
  @@index([localId])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════════════════════
// SYNTHETIC AI INFERENCES
// ═══════════════════════════════════════════════════════════

model SyntheticInference {
  id              String   @id @default(cuid())
  appointmentId   String
  agentType       String
  inferredData    Json?
  confidenceScore Float    @default(0)
  acceptedByUser  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([agentType])
}

model OpeningPhoto {
  id             String    @id @default(cuid())
  companyId      String?
  projectId      String?
  appointmentId  String?
  customerId     String?
  sketchId       String?
  sketchObjectId String?
  openingId      String?
  elevation      String?
  itemType       String?
  markerNumber   Int?
  photoType      String? // exterior_opening, interior_opening, tape_width, etc.
  originalUrl    String?
  annotatedUrl   String?
  thumbnailUrl   String?
  storagePath    String?
  uploadedBy     String?
  capturedAt     DateTime?
  analysisStatus String    @default("pending") // pending, completed, failed
  aiAnalysisJson Json?
  confidence     Float?
  notes          String?
  fileHash       String? // SHA-256 hex of file content — for upload deduplication
  idempotencyKey String? // client idempotency key — prevents double uploads
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  opening     Opening?     @relation(fields: [openingId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([openingId])
  @@index([appointmentId])
  @@index([sketchObjectId])
  @@index([companyId])
  @@index([customerId])
}

model AppointmentPhoto {
  id            String   @id @default(cuid())
  appointmentId String
  companyId     String?
  customerId    String?
  photoUrl      String   // Public or signed URL
  storagePath   String?  // Supabase bucket path (e.g. appointment-photos/{companyId}/{appointmentId}/{uuid}.jpg)
  photoType     String?  // 'front_of_house', 'damage', 'general', 'document'
  description   String?
  uploadedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  company     Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([companyId])
  @@index([customerId])
}

// ═══════════════════════════════════════════════════════════
// PRICING ENGINE
// ═══════════════════════════════════════════════════════════

model PricingVersion {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("draft") // draft | review | published | archived
  publishedAt DateTime?
  publishedBy String?
  importId    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  publisher    User?                @relation(fields: [publishedBy], references: [id], onDelete: Cascade)
  import       PricingImport?       @relation(fields: [importId], references: [id])
  items        PricingVersionItem[]
  appointments Appointment[]

  @@index([publishedBy])
  @@index([importId])
}

model PricingVersionItem {
  id                String   @id @default(cuid())
  pricingVersionId  String
  category          String // product | option | labor | specialty | tax | removal
  productCategory   String?
  seriesModel       String?
  label             String
  unitedInchesMin   Float?
  unitedInchesMax   Float?
  price             Float    @default(0)
  priceType         String   @default("flat")
  confidence        Float    @default(1.0)
  needsVerification Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())

  pricingVersion PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)
  updatedAt      DateTime       @default(now()) @updatedAt

  @@index([pricingVersionId])
  @@index([category])
  @@index([productCategory])
}

model PricingImport {
  id             String   @id @default(cuid())
  fileName       String
  fileType       String // pdf | csv | xlsx | docx
  fileSize       Int?
  source         String   @default("local") // local | google_drive
  driveFileId    String?
  status         String   @default("uploaded") // uploaded | parsing | parsed | reviewed | applied | failed
  parsedRowCount Int?
  errorMessage   String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rows     PricingImportRow[]
  versions PricingVersion[]

  @@index([createdBy])
}

model PricingImportRow {
  id                String   @id @default(cuid())
  importId          String
  rowNumber         Int
  rawData           String? // original text
  category          String?
  productCategory   String?
  seriesModel       String?
  label             String?
  unitedInchesMin   Float?
  unitedInchesMax   Float?
  price             Float?
  priceType         String?
  confidence        Float    @default(0.5)
  needsVerification Boolean  @default(true)
  status            String   @default("pending") // pending | accepted | rejected | edited
  createdAt         DateTime @default(now())

  import    PricingImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  updatedAt DateTime      @default(now()) @updatedAt

  @@index([importId])
}

model MissingPricingRule {
  id              String   @id @default(cuid())
  appointmentId   String?
  openingId       String?
  productCategory String?
  seriesModel     String?
  unitedInches    Float?
  optionLabel     String?
  description     String
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([appointmentId])
  @@index([openingId])
}

// ═══════════════════════════════════════════════════════════
// QUOTES / LINE ITEMS
// ═══════════════════════════════════════════════════════════

model QuoteLineItem {
  id                String      @id @default(cuid())
  appointmentId     String
  openingNumber     Int?
  label             String
  category          String
  quantity          Int         @default(1)
  unitPrice         Float       @default(0)
  totalPrice        Float       @default(0)
  notes             String?
  needsVerification Boolean     @default(false)
  sortOrder         Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  appointment       Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

// ═══════════════════════════════════════════════════════════
// CONTRACTS / SIGNATURES / PAYMENTS
// ═══════════════════════════════════════════════════════════

model Contract {
  id            String      @id @default(cuid())
  appointmentId String
  pdfUrl        String?
  version       Int         @default(1)
  status        String      @default("draft")
  formData      String? // JSON blob of all contract fields
  generatedAt   DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Signature {
  id            String      @id @default(cuid())
  appointmentId String
  signerName    String
  signerRole    String
  signatureData String
  signedAt      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Payment {
  id            String      @id @default(cuid())
  appointmentId String
  amount        Float
  method        String
  reference     String?
  notes         String?
  paidAt        DateTime    @default(now())
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

// ═══════════════════════════════════════════════════════════
// HOUSE MAP / SKETCH
// ═══════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// VOICE-TO-TEXT
// ═══════════════════════════════════════════════════════════

model VoiceSession {
  id            String   @id @default(cuid())
  appointmentId String?
  userId        String
  status        String   @default("recording") // recording | transcribing | parsed | reviewed | applied
  audioUrl      String?
  duration      Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User                   @relation(fields: [userId], references: [id])
  transcripts VoiceTranscript[]
  entities    VoiceExtractedEntity[]

  @@index([appointmentId])
  @@index([userId])
}

model VoiceTranscript {
  id             String   @id @default(cuid())
  voiceSessionId String
  rawText        String
  cleanedText    String?
  confidence     Float    @default(0)
  provider       String? // web_speech | whisper | google
  createdAt      DateTime @default(now())

  voiceSession VoiceSession @relation(fields: [voiceSessionId], references: [id], onDelete: Cascade)
  updatedAt    DateTime     @default(now()) @updatedAt
}

model VoiceExtractedEntity {
  id             String   @id @default(cuid())
  voiceSessionId String
  entityType     String // customer | opening | measurement | option | note
  fieldName      String // e.g. "width", "firstName", "gridStyle"
  fieldValue     String
  openingNumber  Int?
  confidence     Float    @default(0.5)
  status         String   @default("pending") // pending | accepted | rejected | edited
  createdAt      DateTime @default(now())

  voiceSession VoiceSession @relation(fields: [voiceSessionId], references: [id], onDelete: Cascade)
  updatedAt    DateTime     @default(now()) @updatedAt

  @@index([voiceSessionId])
}

// ═══════════════════════════════════════════════════════════
// FORMS ENGINE
// ═══════════════════════════════════════════════════════════

model FormInstance {
  id            String    @id @default(cuid())
  appointmentId String
  formType      String // order_form | contract
  status        String    @default("draft") // draft | filled | reviewed | finalized | exported
  formData      String? // JSON blob
  pdfUrl        String?
  exportedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([formType])
}

// ═══════════════════════════════════════════════════════════
// AUDIT
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @default(now()) @updatedAt

  @@index([entity])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
// PROPERTY IMAGE CACHE
// ═══════════════════════════════════════════════════════════

model PropertyImageCache {
  id                String   @id @default(cuid())
  companyId         String
  customerId        String?
  appointmentId     String?
  normalizedAddress String
  formattedAddress  String
  lat               Float?
  lng               Float?
  source            String // street_view | static_map
  imageUrl          String
