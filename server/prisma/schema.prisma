  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  updatedAt   DateTime    @default(now()) @updatedAt

  @@index([appointmentId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
// SAFETY GLAZING / TEMPERED GLASS
// Louisiana-configurable safety glazing review system
// ═══════════════════════════════════════════════════════════

model OpeningSafetyGlazingReview {
  id                      String    @id @default(cuid())
  appointmentId           String
  openingId               String?
  openingNumber           Int
  safetyReviewStatus      String    @default("not_started")
  // not_started | reviewed | unsure | override | flagged
  temperedRequired        String    @default("not_reviewed")
  // yes | no | unsure | not_reviewed
  temperedFull            Boolean   @default(false)
  temperedHalf            Boolean   @default(false)
  flaggedReasons          String[]  @default([])
  sourceType              String    @default("rule")
  // manual | voice | text | ai | rule | wizard_question
  sourcePhrase            String?
  confidenceScore         Int       @default(0)
  overrideReason          String?
  reviewedBy              String?
  reviewedAt              DateTime?
  // Tempered Rule A — Tub/Shower proximity
  tubOrShowerNearby       String? // yes | no | unknown
  distanceToTubInches     Float?
  // Tempered Rule B — Low glass / large glass
  bottomGlassHeightInches Float?
  glassWidthInches        Float?
  glassHeightInches       Float?
  glassAreaSqft           Float?
  lowGlassConditionMet    Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  metadata                Json?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([openingId])
  @@index([safetyReviewStatus])
  @@index([temperedRequired])
}

model TemperedGlazingFlag {
  id            String   @id @default(cuid())
  reviewId      String?
  appointmentId String
  openingNumber Int
  ruleId        String
  ruleName      String
  category      String
  severity      String   @default("high")
  flagReason    String
  sourceType    String   @default("rule")
  sourcePhrase  String?
  confidence    Float    @default(0.85)
  requiresPhoto Boolean  @default(false)
  photoHint     String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  updatedAt   DateTime    @default(now()) @updatedAt

  @@index([appointmentId])
  @@index([ruleId])
}

model BusinessRuleExecutionLog {
  id             String   @id @default(cuid())
  ruleId         String
  ruleName       String
  appointmentId  String?
  openingId      String?
  openingNumber  Int?
  triggered      Boolean
  autoApplied    Boolean  @default(false)
  overridden     Boolean  @default(false)
  overrideReason String?
  severity       String
  executedAt     DateTime @default(now())
  metadata       Json?
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([ruleId])
  @@index([appointmentId])
  @@index([openingId])
}

model AiValidationWarning {
  id            String    @id @default(cuid())
  appointmentId String
  openingId     String?
  openingNumber Int?
  category      String
  message       String
  sourceType    String    @default("ai")
  sourcePhrase  String?
  confidence    Float     @default(0.75)
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([resolved])
  @@index([openingId])
}

// ═══════════════════════════════════════════════════════════════
// MEASUREMENT INTELLIGENCE — Configurable takeoff/deduction engine
// ═══════════════════════════════════════════════════════════════

model MeasurementRule {
  id                    String    @id @default(cuid())
  companyId             String? // null = global rule visible to all companies
  name                  String
  description           String?
  status                String    @default("needs_verification")
  windowType            String?
  exteriorType          String?
  installType           String?
  removalType           String?
  conditionJson         Json?
  widthTakeoffFraction  String?
  heightTakeoffFraction String?
  widthTakeoffDecimal   Float     @default(0)
  heightTakeoffDecimal  Float     @default(0)
  minDeduction          Float?
  maxDeduction          Float?
  actionType            String    @default("deduct")
  requiresConfirmation  Boolean   @default(true)
  requiresPhoto         Boolean   @default(false)
  requiresNote          Boolean   @default(false)
  severity              String    @default("high")
  notes                 String?
  effectiveDate         DateTime?
  version               Int       @default(1)
  active                Boolean   @default(true)
  createdBy             String?
  updatedBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company     Company?                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  adjustments MeasurementAdjustment[]
  photoReads  MeasurementPhotoRead[]
  execLogs    MeasurementRuleExecutionLog[]

  @@index([companyId])
  @@index([windowType])
  @@index([exteriorType])
  @@index([status])
  @@index([active])
}

// -- LaserMeasurementCapture: stores every laser capture event --
model LaserMeasurementCapture {
  id            String  @id @default(cuid())
  companyId     String
  appointmentId String
  openingId     String?
  customerId    String?
  userId        String

  // Device metadata
  deviceBrand  String  @default("Bosch")
  deviceModel  String  @default("GLM165-27G")
  deviceName   String?
  deviceIdHash String?

  // Capture mode
  captureMode     String // manual | bluetooth_ble | measureon_import | unknown
  protocolVersion String?

  // Raw received data
  rawPayloadText  String?
  rawPayloadJson  Json?
  rawValueText    String // as received/typed, e.g. "36 1/4"
  rawUnit         String? // inches | feet_inches | mm | cm | m | fractional_inches | unknown
  rawValueNumeric Float? // raw value in the rawUnit

  // Normalized values
  normalizedInches       Float? // always in decimal inches
  normalizedFractionText String? // e.g. "36 1/4"

  // Assigned field / context
  assignedField      String? // width | height | leg_height | top_sash_width | return_depth | etc.
  measurementContext String? // free text context

  // Multi-point measurement fields (added 2026-05-31)
  measurementBasis String? // 'outside' | 'inside'
  measurementAxis  String? // 'width' | 'height' | 'depth' | 'diagonal'
  measurementPoint String? // 'top' | 'middle' | 'bottom' | 'left' | 'center' | 'right' | 'diagonal_1' | 'diagonal_2'
  accepted         Boolean @default(true) // false = ignored by user
  ignored          Boolean @default(false)
  ignoreReason     String?
  pointNotes       String?

  // Rule application
  ruleApplied               String?
  deductionInches           Float?
  adjustedOrderInches       Float?
  adjustedOrderFractionText String?

  // Confidence / status
  confidence            Float? // 0-1
  needsUserConfirmation Boolean   @default(true)
  confirmedByUserId     String?
  confirmedAt           DateTime?

  // Suspicious flags
  isSuspicious     Boolean  @default(false)
  suspicionReasons String[] @default([])

  capturedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  metadataJson Json?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([appointmentId])
  @@index([openingId])
  @@index([userId])
  @@index([capturedAt])
  @@index([assignedField])
  @@index([captureMode])
}

model MeasurementAdjustment {
  id                   String    @id @default(cuid())
  appointmentId        String
  openingId            String?
  openingNumber        Int
  sourceType           String    @default("manual")
  rawWidth             Float?
  rawHeight            Float?
  widthTop             Float?
  widthMiddle          Float?
  widthBottom          Float?
  heightLeft           Float?
  heightCenter         Float?
  heightRight          Float?
  adjWidth             Float?
  adjHeight            Float?
  widthTakeoff         Float     @default(0)
  heightTakeoff        Float     @default(0)
  ruleId               String?
  ruleStatus           String?
  confidence           Float?
  approved             Boolean   @default(false)
  approvedBy           String?
  approvedAt           DateTime?
  overrideReason       String?
  notes                String[]  @default([])
  warnings             String[]  @default([])
  metadata             Json?
  // Multi-point session audit fields (added 2026-05-31)
  sizingMethod         String? // 'smallest_opening' | 'manual_override' | 'ai_photo'
  smallestWidthPoint   String? // 'widthTop' | 'widthMiddle' | 'widthBottom'
  smallestHeightPoint  String? // 'heightLeft' | 'heightCenter' | 'heightRight'
  measurementConfirmed Boolean   @default(false)
  obstructionDetected  Boolean   @default(false)
  obstructionType      String? // 'brick' | 'siding' | 'stucco' | 'trim' | 'sill' | 'frame' | 'unknown'
  obstructionNotes     String?
  widthVarianceInches  Float? // spread between highest and lowest width captures
  heightVarianceInches Float? // spread between highest and lowest height captures
  manualOverride       Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  appointment Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  rule        MeasurementRule? @relation(fields: [ruleId], references: [id])

  @@index([appointmentId])
  @@index([approved])
  @@index([openingId])
  @@index([ruleId])
}

model MeasurementCapturePhoto {
  id              String   @id @default(cuid())
  appointmentId   String
  openingId       String?
  openingNumber   Int?
  measurementType String
  photoUrl        String?
  storagePath     String?
  capturedBy      String?
  capturedAt      DateTime @default(now())
  metadata        Json?

  reads MeasurementPhotoRead[]

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  updatedAt   DateTime    @default(now()) @updatedAt

  @@index([appointmentId])
  @@index([openingId])
}

model MeasurementPhotoRead {
  id               String    @id @default(cuid())
  photoId          String?
  appointmentId    String
  openingNumber    Int?
  measurementType  String
  rawAiText        String?
  detectedFraction String?
  detectedDecimal  Float?
  confidenceScore  Float?
  candidates       String[]  @default([])
  selectedValue    Float?
  correctedValue   Float?
  ruleAppliedId    String?
  takeoffAmount    Float?
  finalDecimal     Float?
  finalFraction    String?
  status           String    @default("pending")
  requiresManual   Boolean   @default(false)
  approvedBy       String?
  approvedAt       DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  photo MeasurementCapturePhoto? @relation(fields: [photoId], references: [id], onDelete: SetNull)
  rule  MeasurementRule?         @relation(fields: [ruleAppliedId], references: [id])

  @@index([appointmentId])
  @@index([status])
  @@index([photoId])
  @@index([ruleAppliedId])
}

model MeasurementRuleExecutionLog {
  id             String    @id @default(cuid())
